rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get user role
    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    // Helper: check if user is approved
    function isApproved(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.approved == true;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can create their own profile on signup
      allow create: if isAuth() && request.auth.uid == userId
        && request.resource.data.username is string
        && request.resource.data.email is string
        && request.resource.data.role == 'user';

      // Users can read any profile
      allow read: if isAuth();

      // Users can update their own non-sensitive fields
      allow update: if isAuth() && request.auth.uid == userId
        && (!("role" in request.resource.data) || request.resource.data.role == get(/databases/$(database)/documents/users/$(userId)).data.role)
        && (!("approved" in request.resource.data) || request.resource.data.approved == get(/databases/$(database)/documents/users/$(userId)).data.approved)
        && (!("banned" in request.resource.data) || request.resource.data.banned == get(/databases/$(database)/documents/users/$(userId)).data.banned);

      // Admins and owners can update any user
      allow update: if isAuth()
        && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');

      // Only owner can delete users
      allow delete: if isAuth() && getUserRole(request.auth.uid) == 'owner';

      // Inventory subcollection
      match /inventory/{itemId} {
        allow read: if isAuth();
        allow create, update, delete: if isAuth() && (request.auth.uid == userId || getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');
      }

      // Daily quests subcollection
      match /daily_quests/{questId} {
        allow read: if isAuth();
        allow create, update, delete: if isAuth() && (request.auth.uid == userId || getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');
      }
    }

    // News collection
    match /news/{newsId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');
      allow update, delete: if isAuth()
        && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');
    }

    // Forum collection
    match /forum/{threadId} {
      allow read: if isAuth();
      allow create: if isAuth() && isApproved(request.auth.uid);
      allow update: if isAuth()
        && (request.auth.uid == resource.data.authorId
          || getUserRole(request.auth.uid) == 'admin'
          || getUserRole(request.auth.uid) == 'owner');
      allow delete: if isAuth()
        && (request.auth.uid == resource.data.authorId
          || getUserRole(request.auth.uid) == 'admin'
          || getUserRole(request.auth.uid) == 'owner');
    }

    // Forum replies (subcollection)
    match /forum/{threadId}/replies/{replyId} {
      allow read: if isAuth();
      allow create: if isAuth() && isApproved(request.auth.uid);
      allow delete: if isAuth()
        && (request.auth.uid == resource.data.authorId
          || getUserRole(request.auth.uid) == 'admin'
          || getUserRole(request.auth.uid) == 'owner');
    }

    // Chat collection
    match /chat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && isApproved(request.auth.uid)
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth()
        && (getUserRole(request.auth.uid) == 'admin'
          || getUserRole(request.auth.uid) == 'owner');
    }

    // Events collection
    match /events/{eventId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth()
        && (getUserRole(request.auth.uid) == 'admin'
          || getUserRole(request.auth.uid) == 'owner');
    }

    // Ads collection
    match /ads/{adId} {
      allow read: if true;
      allow create, update, delete: if isAuth()
        && (getUserRole(request.auth.uid) == 'admin'
          || getUserRole(request.auth.uid) == 'owner');
    }

    // Conversations (DMs)
    match /conversations/{convId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      allow delete: if false;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth() && resource.data.senderId == request.auth.uid;
        allow delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // Games collection and hierarchy
    match /games/{gameId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth() && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');

      // Game users (e.g. games/byagai-ot-koce-kisyov/users/{uid})
      match /users/{userId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == userId;
        allow update: if isAuth() && request.auth.uid == userId
          && (!("role" in request.resource.data) || request.resource.data.role == resource.data.role);
        allow delete: if false;
      }

      // Shop subcollection — supports nested categories: games/{gameId}/shop/{category}/items/{itemId}
      match /shop/{category} {
        allow read: if isAuth();
        allow create, update, delete: if isAuth()
          && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');

        match /items/{itemId} {
          allow read: if isAuth();
          allow create, update, delete: if isAuth()
            && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');
        }
      }

      // Leaderboard subcollection
      match /leaderboard/{scoreId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
        allow update: if isAuth() && request.resource.data.user_id == request.auth.uid
          && request.resource.data.score > resource.data.score;
        allow delete: if isAuth() && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'owner');
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
